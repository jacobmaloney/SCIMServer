@page "/users"
@attribute [Authorize]
@using SCIMServer.Core.Models
@using SCIMServer.DataAccess.Repositories
@using SCIMServer.Web.Services
@inject UserRepository UserRepository
@inject GroupRepository GroupRepository
@inject TenantRepository TenantRepo
@inject ActiveSystemState ActiveSystem
@inject DataChangeNotifier DataChange
@inject IJSRuntime JSRuntime
@implements IDisposable

<PageTitle>User Management</PageTitle>

<div class="container-fluid">
    <PageHeader Title="User Management"
                Subtitle="Browse, edit, and provision users in the active Connected System."
                Count="totalCount > 0 ? totalCount : (int?)null"
                CountLabel="Total users in this Connected System">
        <Actions>
            @if (selectedUsers.Any())
            {
                <button class="btn btn-danger" @onclick="BulkDeleteUsers">
                    <i class="oi oi-trash"></i> Delete Selected (@selectedUsers.Count)
                </button>
            }
            <button class="btn btn-outline-secondary" @onclick="ShowDataCleanupModal">
                <i class="oi oi-wrench"></i> Data Cleanup
            </button>
            <button class="btn btn-primary" @onclick="ShowCreateUserModal">
                <i class="oi oi-plus"></i> Create User
            </button>
        </Actions>
    </PageHeader>

    @if (loading)
    {
        <div class="text-center py-5">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="utable">
                <thead>
                    <tr>
                        <th class="check-col">
                            <input type="checkbox" class="form-check-input" @onchange="ToggleSelectAll" checked="@allSelected" />
                        </th>
                        <th>User</th>
                        <th>Department · Title</th>
                        <th>Status</th>
                        <th>Manager</th>
                        <th>Created</th>
                        <th class="act-col">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in users)
                    {
                        var initials = InitialsFor(user);
                        var primaryEmail = user.Emails?.FirstOrDefault(e => e.Primary)?.Value ?? user.UserName;
                        <tr class="@(selectedUsers.Contains(user.Id) ? "sel" : "")" @onclick="() => OpenDrawer(user)">
                            <td class="check-col" @onclick:stopPropagation="true">
                                <input type="checkbox" class="form-check-input" value="@user.Id"
                                       checked="@selectedUsers.Contains(user.Id)"
                                       @onchange="@(() => ToggleUserSelection(user.Id))" />
                            </td>
                            <td>
                                <div class="user-cell">
                                    <span class="avatar avatar-28">@initials</span>
                                    <div class="user-cell-text">
                                        <span class="user-cell-name">@(string.IsNullOrWhiteSpace(user.DisplayName) ? user.UserName : user.DisplayName)</span>
                                        <span class="user-cell-email">@primaryEmail</span>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <div class="dept-cell">
                                    <span class="dept-cell-dept">@(user.EnterpriseExtension?.Department ?? "—")</span>
                                    <span class="dept-cell-title">@(user.Title ?? "")</span>
                                </div>
                            </td>
                            <td>
                                @if (user.Active)
                                {
                                    <span class="status-pill ok">Active</span>
                                }
                                else
                                {
                                    <span class="status-pill muted">Suspended</span>
                                }
                            </td>
                            <td class="text-muted" style="font-size: 12.5px;">@(user.EnterpriseExtension?.Manager?.DisplayName ?? "—")</td>
                            <td class="mono-date">@user.Meta.Created.ToString("yyyy-MM-dd")</td>
                            <td class="act-col" @onclick:stopPropagation="true">
                                <button class="row-act" @onclick="() => ShowUserGroupsModal(user)" title="Manage Groups">
                                    <i class="oi oi-badge"></i>
                                </button>
                                <button class="row-act" @onclick="() => EditUser(user)" title="Edit User">
                                    <i class="oi oi-pencil"></i>
                                </button>
                                <button class="row-act" @onclick="() => DeleteUser(user)" title="Delete User">
                                    <i class="oi oi-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <nav>
            <ul class="pagination">
                <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                    <button class="page-link" @onclick="() => LoadUsers(currentPage - 1)">Previous</button>
                </li>
                @for (int i = 1; i <= totalPages; i++)
                {
                    var pageNum = i;
                    <li class="page-item @(currentPage == pageNum ? "active" : "")">
                        <button class="page-link" @onclick="() => LoadUsers(pageNum)">@pageNum</button>
                    </li>
                }
                <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                    <button class="page-link" @onclick="() => LoadUsers(currentPage + 1)">Next</button>
                </li>
            </ul>
        </nav>
    }
</div>

@* User detail drawer — slides in from the right on row click. *@
@if (drawerUser is not null)
{
    var ext = drawerUser.EnterpriseExtension;
    var primary = drawerUser.Emails?.FirstOrDefault(e => e.Primary)?.Value
                  ?? drawerUser.Emails?.FirstOrDefault()?.Value;
    var work = drawerUser.PhoneNumbers?.FirstOrDefault(p => p.Type == "work")?.Value
               ?? drawerUser.PhoneNumbers?.FirstOrDefault()?.Value;

    <div class="drawer-veil" @onclick="CloseDrawer"></div>
    <aside class="drawer">
        <div class="drawer-head">
            <button class="drawer-close" @onclick="CloseDrawer" title="Close (Esc)">
                <i class="oi oi-x"></i>
            </button>
            <div class="drawer-head-main">
                <span class="avatar avatar-40">@InitialsFor(drawerUser)</span>
                <div>
                    <h2>@(string.IsNullOrWhiteSpace(drawerUser.DisplayName) ? drawerUser.UserName : drawerUser.DisplayName)</h2>
                    <div class="drawer-email">@drawerUser.UserName</div>
                </div>
            </div>
            <div class="drawer-pills">
                @if (drawerUser.Active)
                {
                    <span class="status-pill ok">Active</span>
                }
                else
                {
                    <span class="status-pill muted">Suspended</span>
                }
                @if (!string.IsNullOrWhiteSpace(ext?.Department))
                {
                    <span class="kind-pill">@ext.Department</span>
                }
                @if (!string.IsNullOrWhiteSpace(ext?.EmployeeNumber))
                {
                    <span class="badge mono" style="background: var(--bg-2); color: var(--ink-2); padding: 2px 6px; font-family: var(--font-mono); font-size: 10.5px;">@ext.EmployeeNumber</span>
                }
            </div>
        </div>
        <div class="drawer-tabs">
            <button class="@(drawerTab == "overview" ? "cur" : "")" @onclick='() => drawerTab = "overview"'>Overview</button>
            <button class="@(drawerTab == "raw" ? "cur" : "")" @onclick='() => drawerTab = "raw"'>Raw JSON</button>
        </div>
        <div class="drawer-body">
            @if (drawerTab == "overview")
            {
                <section class="drawer-section">
                    <h4>Profile</h4>
                    <dl class="kv">
                        <dt>Display name</dt><dd>@(drawerUser.DisplayName ?? "—")</dd>
                        <dt>Username</dt><dd class="mono">@drawerUser.UserName</dd>
                        <dt>Email</dt><dd>@(primary ?? "—")</dd>
                        <dt>Title</dt><dd>@(drawerUser.Title ?? "—")</dd>
                        <dt>Phone</dt><dd>@(work ?? "—")</dd>
                    </dl>
                </section>
                <section class="drawer-section">
                    <h4>Organization</h4>
                    <dl class="kv">
                        <dt>Department</dt><dd>@(ext?.Department ?? "—")</dd>
                        <dt>Manager</dt><dd>@(ext?.Manager?.DisplayName ?? "—")</dd>
                        <dt>Employee #</dt><dd class="mono">@(ext?.EmployeeNumber ?? "—")</dd>
                        <dt>Cost center</dt><dd>@(ext?.CostCenter ?? "—")</dd>
                        <dt>Organization</dt><dd>@(ext?.Organization ?? "—")</dd>
                    </dl>
                </section>
                <section class="drawer-section">
                    <h4>SCIM metadata</h4>
                    <dl class="kv">
                        <dt>ID</dt><dd class="mono">@drawerUser.Id</dd>
                        <dt>External ID</dt><dd class="mono">@(drawerUser.ExternalId ?? "—")</dd>
                        <dt>Created</dt><dd class="mono">@drawerUser.Meta.Created.ToString("yyyy-MM-dd HH:mm")</dd>
                        <dt>Modified</dt><dd class="mono">@drawerUser.Meta.LastModified.ToString("yyyy-MM-dd HH:mm")</dd>
                        <dt>Version</dt><dd class="mono">@(drawerUser.Meta.Version ?? "1")</dd>
                    </dl>
                </section>
            }
            else if (drawerTab == "raw")
            {
                <section class="drawer-section">
                    <h4>Raw SCIM resource</h4>
                    <pre class="drawer-json">@RawJsonFor(drawerUser)</pre>
                </section>
            }
        </div>
        <div class="drawer-foot">
            <button class="btn btn-outline-secondary" @onclick="() => ShowUserGroupsModal(drawerUser)">
                <i class="oi oi-badge"></i> Manage groups
            </button>
            <button class="btn btn-primary" @onclick="() => OpenEditFromDrawer(drawerUser)">
                <i class="oi oi-pencil"></i> Edit
            </button>
        </div>
    </aside>
}

<!-- Create/Edit User Modal -->
<div class="modal @(showUserModal ? "show d-block" : "")" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">@(editingUser?.Id != null ? "Edit User" : "Create User")</h5>
                <button type="button" class="btn-close" @onclick="CloseUserModal"></button>
            </div>
            <div class="modal-body">
                <form>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Username *</label>
                                <input type="text" class="form-control" @bind="editingUser!.UserName" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Display Name</label>
                                <input type="text" class="form-control" @bind="editingUser.DisplayName" />
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Given Name</label>
                                <input type="text" class="form-control" @bind="editingUser!.Name!.GivenName" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Family Name</label>
                                <input type="text" class="form-control" @bind="editingUser.Name.FamilyName" />
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input type="email" class="form-control" @bind="primaryEmail" />
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Department</label>
                                <input type="text" class="form-control" @bind="editingUser!.EnterpriseExtension!.Department" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Employee Number</label>
                                <input type="text" class="form-control" @bind="editingUser.EnterpriseExtension.EmployeeNumber" />
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Manager</label>
                        <input type="text" class="form-control mb-1" placeholder="Search managers by name or username..."
                               @bind="managerSearchText" @bind:event="oninput" />
                        <select class="form-select" size="6" @onchange="OnManagerSelected">
                            <option value="">— No manager —</option>
                            @foreach (var candidate in FilteredManagerCandidates())
                            {
                                <option value="@candidate.Id" selected="@(editingUser.EnterpriseExtension?.Manager?.Value == candidate.Id)">
                                    @(candidate.DisplayName ?? candidate.UserName) (@candidate.UserName)
                                </option>
                            }
                        </select>
                        @if (editingUser.EnterpriseExtension?.Manager?.Value is { Length: > 0 })
                        {
                            <small class="form-text text-muted">
                                Current: <strong>@(editingUser.EnterpriseExtension.Manager.DisplayName ?? editingUser.EnterpriseExtension.Manager.Value)</strong>
                                <button type="button" class="btn btn-link btn-sm p-0 ms-2" @onclick="ClearManager">clear</button>
                            </small>
                        }
                    </div>

                    <div class="form-check mb-3">
                        <input type="checkbox" class="form-check-input" @bind="editingUser.Active" />
                        <label class="form-check-label">Active</label>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" @onclick="CloseUserModal">Cancel</button>
                <button type="button" class="btn btn-primary" @onclick="SaveUser">Save</button>
            </div>
        </div>
    </div>
</div>


@if (showUserModal)
{
    <div class="modal-backdrop fade show"></div>
}

<!-- User Groups Management Modal -->
<div class="modal @(showUserGroupsModal ? "show d-block" : "")" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="oi oi-badge"></i> Groups for @currentUserForGroups?.DisplayName
                </h5>
                <button type="button" class="btn-close" @onclick="CloseUserGroupsModal"></button>
            </div>
            <div class="modal-body">
                @if (currentUserForGroups != null)
                {
                    <!-- User's Current Groups -->
                    <div class="card mb-3">
                        <div class="card-body">
                            <h6 class="card-title">Current Group Memberships (@userGroups.Count)</h6>
                            @if (!userGroups.Any())
                            {
                                <div class="alert alert-info mb-0">
                                    <i class="oi oi-info"></i> This user is not a member of any groups.
                                </div>
                            }
                            else
                            {
                                <div class="table-responsive">
                                    <table class="table table-sm">
                                        <thead>
                                            <tr>
                                                <th>Group Name</th>
                                                <th>Type</th>
                                                <th>Role</th>
                                                <th>Actions</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var groupMembership in userGroups)
                                            {
                                                <tr>
                                                    <td>
                                                        <strong>@groupMembership.GroupName</strong>
                                                        @if (!string.IsNullOrEmpty(groupMembership.GroupDescription))
                                                        {
                                                            <br /><small class="text-muted">@groupMembership.GroupDescription</small>
                                                        }
                                                    </td>
                                                    <td>
                                                        <span class="badge bg-secondary">@(groupMembership.GroupType ?? "Group")</span>
                                                    </td>
                                                    <td>
                                                        @if (groupMembership.IsOwner)
                                                        {
                                                            <span class="badge bg-warning">Owner</span>
                                                        }
                                                        else
                                                        {
                                                            <span class="badge bg-primary">Member</span>
                                                        }
                                                    </td>
                                                    <td>
                                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => RemoveUserFromGroup(groupMembership)">
                                                            <i class="oi oi-x"></i> Remove
                                                        </button>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" @onclick="CloseUserGroupsModal">Close</button>
                @if (userGroupChangesPresent)
                {
                    <button type="button" class="btn btn-primary" @onclick="SaveUserGroupChanges">
                        <i class="oi oi-check"></i> Save Changes
                    </button>
                }
            </div>
        </div>
    </div>
</div>

@if (showUserGroupsModal)
{
    <div class="modal-backdrop fade show"></div>
}

<!-- Data Cleanup Modal -->
<div class="modal @(showDataCleanupModal ? "show d-block" : "")" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="oi oi-wrench"></i> Data Cleanup Options
                </h5>
                <button type="button" class="btn-close" @onclick="CloseDataCleanupModal"></button>
            </div>
            <div class="modal-body">
                <div class="alert alert-warning">
                    <i class="oi oi-warning"></i> <strong>Warning:</strong> These operations cannot be undone. Please be careful.
                </div>

                <div class="card mb-3" style="border-left: 3px solid var(--accent);">
                    <div class="card-body">
                        <h6 class="card-title mb-2">Scope</h6>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="cleanupScope" id="cleanupScopeTenant"
                                   checked="@(cleanupScope == "tenant")"
                                   @onchange="@(() => cleanupScope = "tenant")"
                                   disabled="@(ActiveSystem.ActiveSystem is null || cleanupInProgress)" />
                            <label class="form-check-label" for="cleanupScopeTenant">
                                <strong>This Connected System only</strong>
                                @if (ActiveSystem.ActiveSystem is { } s)
                                {
                                    <span class="text-muted"> — @s.Name (<code>@s.Slug</code>)</span>
                                }
                                else
                                {
                                    <span class="text-muted"> — pick one in the sidebar to enable</span>
                                }
                            </label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="cleanupScope" id="cleanupScopeAll"
                                   checked="@(cleanupScope == "all")"
                                   @onchange="@(() => cleanupScope = "all")"
                                   disabled="@cleanupInProgress" />
                            <label class="form-check-label" for="cleanupScopeAll">
                                <strong class="text-danger">Entire system</strong>
                                <span class="text-muted"> — every Connected System in the database</span>
                            </label>
                        </div>
                    </div>
                </div>

                <div class="card mb-3">
                    <div class="card-body">
                        <h6 class="card-title">Clear All Group Memberships</h6>
                        <p class="card-text">Remove all users from all groups while keeping the groups themselves.</p>
                        <button class="btn btn-outline-warning" @onclick="ClearAllMemberships" disabled="@cleanupInProgress">
                            <i class="oi oi-layers"></i> Clear Memberships
                        </button>
                    </div>
                </div>
                
                <div class="card mb-3">
                    <div class="card-body">
                        <h6 class="card-title">Delete All Groups</h6>
                        <p class="card-text">Delete all groups and their memberships.</p>
                        <button class="btn btn-outline-danger" @onclick="DeleteAllGroups" disabled="@cleanupInProgress">
                            <i class="oi oi-trash"></i> Delete All Groups
                        </button>
                    </div>
                </div>
                
                <div class="card mb-3">
                    <div class="card-body">
                        <h6 class="card-title">Delete All Users</h6>
                        <p class="card-text">Delete all users and remove them from groups.</p>
                        <button class="btn btn-outline-danger" @onclick="DeleteAllUsers" disabled="@cleanupInProgress">
                            <i class="oi oi-trash"></i> Delete All Users
                        </button>
                    </div>
                </div>
                
                <div class="card">
                    <div class="card-body">
                        <h6 class="card-title text-danger">Complete Data Reset</h6>
                        <p class="card-text">Delete all users, groups, and memberships. This will reset the system to empty state.</p>
                        <button class="btn btn-danger" @onclick="CompleteDataReset" disabled="@cleanupInProgress">
                            <i class="oi oi-warning"></i> Reset Everything
                        </button>
                    </div>
                </div>
                
                @if (cleanupInProgress)
                {
                    <div class="text-center mt-3">
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">Processing...</span>
                        </div>
                        <p class="mt-2">@cleanupMessage</p>
                    </div>
                }
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" @onclick="CloseDataCleanupModal" disabled="@cleanupInProgress">Close</button>
            </div>
        </div>
    </div>
</div>

@if (showDataCleanupModal)
{
    <div class="modal-backdrop fade show"></div>
}

@code {
    // ── User detail drawer state ────────────────────────────────────────
    private ScimUser? drawerUser;
    private string drawerTab = "overview";

    private void OpenDrawer(ScimUser u)
    {
        drawerUser = u;
        drawerTab = "overview";
    }

    private void CloseDrawer() => drawerUser = null;

    private async Task OpenEditFromDrawer(ScimUser u)
    {
        // Drawer is the read view; the existing modal handles edits.
        drawerUser = null;
        await EditUser(u);
    }

    private static string RawJsonFor(ScimUser u)
    {
        var primary = u.Emails?.FirstOrDefault(e => e.Primary)
                      ?? u.Emails?.FirstOrDefault();
        var payload = new
        {
            schemas = new[] {
                "urn:ietf:params:scim:schemas:core:2.0:User",
                "urn:ietf:params:scim:schemas:extension:enterprise:2.0:User"
            },
            id = u.Id,
            externalId = u.ExternalId,
            userName = u.UserName,
            name = u.Name == null ? null : new
            {
                formatted = u.Name.Formatted,
                familyName = u.Name.FamilyName,
                givenName = u.Name.GivenName
            },
            displayName = u.DisplayName,
            title = u.Title,
            active = u.Active,
            emails = u.Emails?.Select(e => new { e.Value, e.Type, e.Primary }),
            phoneNumbers = u.PhoneNumbers?.Select(p => new { p.Value, p.Type }),
            enterprise = new
            {
                department = u.EnterpriseExtension?.Department,
                manager = u.EnterpriseExtension?.Manager?.DisplayName,
                employeeNumber = u.EnterpriseExtension?.EmployeeNumber,
                costCenter = u.EnterpriseExtension?.CostCenter,
                organization = u.EnterpriseExtension?.Organization
            },
            meta = new
            {
                resourceType = u.Meta.ResourceType,
                created = u.Meta.Created,
                lastModified = u.Meta.LastModified,
                version = u.Meta.Version
            }
        };
        return System.Text.Json.JsonSerializer.Serialize(payload, new System.Text.Json.JsonSerializerOptions
        {
            WriteIndented = true,
            DefaultIgnoreCondition = System.Text.Json.Serialization.JsonIgnoreCondition.WhenWritingNull
        });
    }

    private static string InitialsFor(ScimUser u)
    {
        // Prefer first letter of given + family. Fall back to first two letters of
        // display name, then first two of userName, then "?". Always uppercase.
        var given = u.Name?.GivenName?.Trim();
        var family = u.Name?.FamilyName?.Trim();
        if (!string.IsNullOrEmpty(given) && !string.IsNullOrEmpty(family))
            return string.Concat(char.ToUpperInvariant(given[0]), char.ToUpperInvariant(family[0]));
        var src = !string.IsNullOrWhiteSpace(u.DisplayName) ? u.DisplayName!.Trim()
                : !string.IsNullOrWhiteSpace(u.UserName) ? u.UserName!.Trim()
                : "?";
        var letters = src.Where(char.IsLetterOrDigit).Take(2).ToArray();
        if (letters.Length == 0) return "?";
        return new string(letters.Select(char.ToUpperInvariant).ToArray());
    }

    private List<ScimUser> users = new();
    private bool loading = true;
    private int currentPage = 1;
    private int pageSize = 10;
    private int totalCount = 0;
    private int totalPages = 1;
    
    private HashSet<string> selectedUsers = new();
    private bool allSelected = false;

    private bool showUserModal = false;
    private ScimUser editingUser = new() 
    { 
        Name = new ScimName(), 
        EnterpriseExtension = new ScimEnterpriseUser() 
    };
    private string primaryEmail = "";
    
    // User groups modal variables
    private bool showUserGroupsModal = false;
    private ScimUser? currentUserForGroups = null;
    private List<UserGroupMembership> userGroups = new();
    private bool userGroupChangesPresent = false;
    
    // Data cleanup modal variables
    private bool showDataCleanupModal = false;
    private bool cleanupInProgress = false;
    private string cleanupMessage = "";
    
    public class UserGroupMembership
    {
        public string GroupId { get; set; } = "";
        public string GroupName { get; set; } = "";
        public string? GroupDescription { get; set; }
        public string? GroupType { get; set; }
        public bool IsOwner { get; set; }
    }

    // ActiveSystemState (driven by the sidebar switcher) is the only source of
    // truth for which Connected System we're scoped to. The page-level filter
    // dropdown was removed — its replacement is the <ContextLabel /> badge in
    // the page header that shows the active system + a hint when 'All' is set.

    protected override async Task OnInitializedAsync()
    {
        ActiveSystem.OnChangeAsync += HandleActiveSystemChangedAsync;
        await LoadUsers(1);
    }

    public void Dispose()
    {
        ActiveSystem.OnChangeAsync -= HandleActiveSystemChangedAsync;
    }

    private async Task HandleActiveSystemChangedAsync()
    {
        await InvokeAsync(async () =>
        {
            await LoadUsers(1);
            StateHasChanged();
        });
    }

    private async Task LoadUsers(int page)
    {
        loading = true;
        currentPage = page;

        var options = new ScimQueryOptions
        {
            StartIndex = (page - 1) * pageSize + 1,
            Count = pageSize
        };

        // The active Connected System (from the sidebar switcher) is the source of
        // truth. The page-level dropdown is mirrored to it on init / state change.
        var override_ = ActiveSystem.ActiveSystem?.Id;
        var (loadedUsers, count) = await UserRepository.GetAllAsync(options, tenantIdOverride: override_);
        users = loadedUsers;
        totalCount = count;
        totalPages = (int)Math.Ceiling((double)totalCount / pageSize);

        loading = false;
        // Fan out so the sidebar count badge stays in sync. Cheap COUNT-only refresh.
        await DataChange.NotifyAsync(DataChangeKind.Users);
    }

    // Manager picker — populated each time the edit modal opens so the candidate set
    // tracks the active Connected System.
    private List<ScimUser> managerCandidates = new();
    private string managerSearchText = "";

    private async Task ShowCreateUserModal()
    {
        editingUser = new ScimUser
        {
            Name = new ScimName(),
            EnterpriseExtension = new ScimEnterpriseUser()
        };
        primaryEmail = "";
        await LoadManagerCandidatesAsync(null);
        showUserModal = true;
    }

    private async Task EditUser(ScimUser user)
    {
        editingUser = user; // In real app, deep clone

        // Ensure required properties are initialized
        if (editingUser.Name == null)
            editingUser.Name = new ScimName();
        if (editingUser.EnterpriseExtension == null)
            editingUser.EnterpriseExtension = new ScimEnterpriseUser();

        primaryEmail = user.Emails?.FirstOrDefault(e => e.Primary)?.Value ?? "";
        await LoadManagerCandidatesAsync(user.Id);
        showUserModal = true;
    }

    private async Task LoadManagerCandidatesAsync(string? excludeUserId)
    {
        managerSearchText = "";
        try
        {
            var (loaded, _) = await UserRepository.GetAllAsync(
                new ScimQueryOptions { StartIndex = 1, Count = 500 });
            managerCandidates = loaded
                .Where(u => excludeUserId == null || u.Id != excludeUserId)
                .ToList();
        }
        catch
        {
            managerCandidates = new();
        }
    }

    private IEnumerable<ScimUser> FilteredManagerCandidates()
    {
        if (string.IsNullOrWhiteSpace(managerSearchText)) return managerCandidates.Take(100);
        var q = managerSearchText.Trim();
        return managerCandidates
            .Where(u =>
                (u.DisplayName ?? "").Contains(q, StringComparison.OrdinalIgnoreCase) ||
                (u.UserName ?? "").Contains(q, StringComparison.OrdinalIgnoreCase))
            .Take(100);
    }

    private void OnManagerSelected(ChangeEventArgs e)
    {
        var v = e.Value?.ToString();
        if (editingUser.EnterpriseExtension == null)
            editingUser.EnterpriseExtension = new ScimEnterpriseUser();
        if (string.IsNullOrEmpty(v))
        {
            editingUser.EnterpriseExtension.Manager = null;
        }
        else
        {
            var picked = managerCandidates.FirstOrDefault(u => u.Id == v);
            editingUser.EnterpriseExtension.Manager = new ScimManager
            {
                Value = v,
                DisplayName = picked?.DisplayName ?? picked?.UserName
            };
        }
    }

    private void ClearManager()
    {
        if (editingUser.EnterpriseExtension != null)
        {
            editingUser.EnterpriseExtension.Manager = null;
        }
    }

    private void CloseUserModal()
    {
        showUserModal = false;
        editingUser = new() 
        { 
            Name = new ScimName(), 
            EnterpriseExtension = new ScimEnterpriseUser() 
        };
        primaryEmail = "";
    }

    private async Task SaveUser()
    {
        if (string.IsNullOrWhiteSpace(editingUser.UserName))
        {
            await JSRuntime.InvokeVoidAsync("alert", "Username is required");
            return;
        }

        // Set email if provided
        if (!string.IsNullOrWhiteSpace(primaryEmail))
        {
            editingUser.Emails.Clear();
            editingUser.Emails.Add(new ScimEmail
            {
                Value = primaryEmail,
                Type = "work",
                Primary = true
            });
        }

        try
        {
            if (string.IsNullOrEmpty(editingUser.Id))
            {
                await UserRepository.CreateAsync(editingUser);
            }
            else
            {
                await UserRepository.UpdateAsync(Guid.Parse(editingUser.Id), editingUser);
            }

            CloseUserModal();
            await LoadUsers(currentPage);
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Error saving user: {ex.Message}");
        }
    }

    private async Task DeleteUser(ScimUser user)
    {
        var confirm = await JSRuntime.InvokeAsync<bool>("confirm", $"Are you sure you want to delete user '{user.UserName}'?");
        if (confirm)
        {
            try
            {
                await UserRepository.DeleteAsync(Guid.Parse(user.Id));
                await LoadUsers(currentPage);
            }
            catch (Exception ex)
            {
                await JSRuntime.InvokeVoidAsync("alert", $"Error deleting user: {ex.Message}");
            }
        }
    }

    private void ToggleUserSelection(string userId)
    {
        if (selectedUsers.Contains(userId))
        {
            selectedUsers.Remove(userId);
        }
        else
        {
            selectedUsers.Add(userId);
        }
        
        allSelected = selectedUsers.Count == users.Count;
    }

    private void ToggleSelectAll(ChangeEventArgs e)
    {
        if ((bool)(e.Value ?? false))
        {
            selectedUsers = new HashSet<string>(users.Select(u => u.Id));
            allSelected = true;
        }
        else
        {
            selectedUsers.Clear();
            allSelected = false;
        }
    }

    private async Task BulkDeleteUsers()
    {
        if (!selectedUsers.Any())
            return;

        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", 
            $"Are you sure you want to delete {selectedUsers.Count} selected users? This action cannot be undone.");
        
        if (!confirmed)
            return;

        loading = true;
        
        try
        {
            foreach (var userId in selectedUsers)
            {
                await UserRepository.DeleteAsync(Guid.Parse(userId));
            }
            
            selectedUsers.Clear();
            allSelected = false;
            await LoadUsers(currentPage);
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Error deleting users: {ex.Message}");
        }
        finally
        {
            loading = false;
        }
    }
    
    private async Task ShowUserGroupsModal(ScimUser user)
    {
        try
        {
            currentUserForGroups = user;
            await LoadUserGroups();
            userGroupChangesPresent = false;
            showUserGroupsModal = true;
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Error loading user groups: {ex.Message}");
        }
    }
    
    private async Task LoadUserGroups()
    {
        if (currentUserForGroups == null) return;
        
        try
        {
            userGroups.Clear();
            
            // Get all groups and find ones this user belongs to
            var (allGroups, _) = await GroupRepository.GetAllAsync(new ScimQueryOptions { StartIndex = 1, Count = 10000 });
            
            foreach (var group in allGroups)
            {
                // Check if user is a member
                var isMember = group.Members?.Any(m => m.Value == currentUserForGroups.Id) ?? false;
                // Check if user is the owner
                var isOwner = group.Owner?.Value == currentUserForGroups.Id;
                
                if (isMember || isOwner)
                {
                    userGroups.Add(new UserGroupMembership
                    {
                        GroupId = group.Id,
                        GroupName = group.DisplayName,
                        GroupDescription = group.Description,
                        GroupType = group.Type,
                        IsOwner = isOwner
                    });
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading user groups: {ex.Message}");
        }
    }
    
    private async Task RemoveUserFromGroup(UserGroupMembership groupMembership)
    {
        if (currentUserForGroups == null) return;
        
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", 
            $"Remove {currentUserForGroups.DisplayName} from group '{groupMembership.GroupName}'?");
            
        if (!confirmed) return;
        
        try
        {
            var group = await GroupRepository.GetByIdAsync(Guid.Parse(groupMembership.GroupId));
            if (group != null)
            {
                // Remove from members
                group.Members = group.Members?.Where(m => m.Value != currentUserForGroups.Id).ToList() ?? new List<ScimGroupMember>();
                
                // Remove as owner if applicable
                if (group.Owner?.Value == currentUserForGroups.Id)
                {
                    group.Owner = null;
                }
                
                await GroupRepository.UpdateAsync(Guid.Parse(group.Id), group);
                await LoadUserGroups();
                userGroupChangesPresent = true;
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Error removing user from group: {ex.Message}");
        }
    }
    
    private void CloseUserGroupsModal()
    {
        showUserGroupsModal = false;
        currentUserForGroups = null;
        userGroups.Clear();
        userGroupChangesPresent = false;
    }
    
    private async Task SaveUserGroupChanges()
    {
        // Changes are already saved in real-time, just close modal
        await JSRuntime.InvokeVoidAsync("alert", "Changes saved successfully!");
        CloseUserGroupsModal();
    }
    
    // "tenant" = limit cleanup to the active Connected System; "all" = sweep every system.
    // Default biases toward the safer scope when a system is selected.
    private string cleanupScope = "tenant";

    private Guid? CleanupTenantOverride =>
        cleanupScope == "tenant" ? ActiveSystem.ActiveSystem?.Id : (Guid?)null;

    private string CleanupScopeLabel =>
        cleanupScope == "tenant"
            ? (ActiveSystem.ActiveSystem?.Name ?? "(no system selected)")
            : "ALL Connected Systems";

    private void ShowDataCleanupModal()
    {
        cleanupScope = ActiveSystem.ActiveSystem is null ? "all" : "tenant";
        showDataCleanupModal = true;
    }
    
    private void CloseDataCleanupModal()
    {
        showDataCleanupModal = false;
        cleanupInProgress = false;
        cleanupMessage = "";
    }
    
    private async Task ClearAllMemberships()
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm",
            $"Clear all group memberships in {CleanupScopeLabel}? Groups stay; users are removed from them.");

        if (!confirmed) return;

        cleanupInProgress = true;
        cleanupMessage = $"Clearing group memberships in {CleanupScopeLabel}...";
        StateHasChanged();

        try
        {
            var (allGroups, _) = await GroupRepository.GetAllAsync(
                new ScimQueryOptions { StartIndex = 1, Count = 10000 },
                tenantIdOverride: CleanupTenantOverride);

            foreach (var group in allGroups)
            {
                group.Members?.Clear();
                group.Owner = null;
                await GroupRepository.UpdateAsync(Guid.Parse(group.Id), group);
            }

            await JSRuntime.InvokeVoidAsync("alert", $"Cleared memberships across {allGroups.Count} groups in {CleanupScopeLabel}.");
            CloseDataCleanupModal();
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Error clearing memberships: {ex.Message}");
        }
        finally
        {
            cleanupInProgress = false;
        }
    }
    
    private async Task DeleteAllGroups()
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm",
            $"Delete ALL groups in {CleanupScopeLabel}? This cannot be undone.");

        if (!confirmed) return;

        cleanupInProgress = true;
        cleanupMessage = $"Deleting groups in {CleanupScopeLabel}...";
        StateHasChanged();

        try
        {
            var (allGroups, _) = await GroupRepository.GetAllAsync(
                new ScimQueryOptions { StartIndex = 1, Count = 10000 },
                tenantIdOverride: CleanupTenantOverride);

            foreach (var group in allGroups)
            {
                await GroupRepository.DeleteAsync(Guid.Parse(group.Id));
            }

            await JSRuntime.InvokeVoidAsync("alert", $"Deleted {allGroups.Count} groups from {CleanupScopeLabel}.");
            CloseDataCleanupModal();
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Error deleting groups: {ex.Message}");
        }
        finally
        {
            cleanupInProgress = false;
        }
    }
    
    private async Task DeleteAllUsers()
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm",
            $"Delete ALL users in {CleanupScopeLabel}? This cannot be undone.");

        if (!confirmed) return;

        cleanupInProgress = true;
        cleanupMessage = $"Deleting users in {CleanupScopeLabel}...";
        StateHasChanged();

        try
        {
            var (allUsers, _) = await UserRepository.GetAllAsync(
                new ScimQueryOptions { StartIndex = 1, Count = 10000 },
                tenantIdOverride: CleanupTenantOverride);

            foreach (var user in allUsers)
            {
                await UserRepository.DeleteAsync(Guid.Parse(user.Id));
            }

            await JSRuntime.InvokeVoidAsync("alert", $"Deleted {allUsers.Count} users from {CleanupScopeLabel}.");
            await LoadUsers(1);
            CloseDataCleanupModal();
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Error deleting users: {ex.Message}");
        }
        finally
        {
            cleanupInProgress = false;
        }
    }
    
    private async Task CompleteDataReset()
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm",
            $"Reset ALL data in {CleanupScopeLabel}? Users, groups, and memberships will be deleted. This CANNOT be undone.");

        if (!confirmed) return;

        cleanupInProgress = true;
        cleanupMessage = $"Resetting data in {CleanupScopeLabel}...";
        StateHasChanged();

        try
        {
            // Delete all users first
            var (allUsers, _) = await UserRepository.GetAllAsync(
                new ScimQueryOptions { StartIndex = 1, Count = 10000 },
                tenantIdOverride: CleanupTenantOverride);
            foreach (var user in allUsers)
            {
                await UserRepository.DeleteAsync(Guid.Parse(user.Id));
            }

            // Delete all groups
            var (allGroups, _) = await GroupRepository.GetAllAsync(
                new ScimQueryOptions { StartIndex = 1, Count = 10000 },
                tenantIdOverride: CleanupTenantOverride);
            foreach (var group in allGroups)
            {
                await GroupRepository.DeleteAsync(Guid.Parse(group.Id));
            }

            await JSRuntime.InvokeVoidAsync("alert", $"Reset complete: deleted {allUsers.Count} users and {allGroups.Count} groups from {CleanupScopeLabel}.");
            await LoadUsers(1);
            CloseDataCleanupModal();
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Error during data reset: {ex.Message}");
        }
        finally
        {
            cleanupInProgress = false;
        }
    }
