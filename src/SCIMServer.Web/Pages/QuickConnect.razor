@page "/quick-connect"
@attribute [Authorize]
@using Microsoft.AspNetCore.Hosting
@inject IWebHostEnvironment Environment
@inject NavigationManager Navigation
@inject IConfiguration Configuration

<PageTitle>Quick Connect - SCIM Server</PageTitle>

<div class="container-fluid">
    <h1>SCIM Quick Connect</h1>
    <p class="lead">Connection details and testing information for SCIM 2.0 integration</p>

    <div class="row">
        <div class="col-lg-8">
            <!-- Connection Details -->
            <div class="card mb-4">
                <div class="card-header">
                    <h3 class="mb-0"><i class="oi oi-link-intact"></i> Connection Details</h3>
                </div>
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-3">Base URL:</dt>
                        <dd class="col-sm-9">
                            <code class="user-select-all">@baseUrl</code>
                            <button class="btn btn-sm btn-outline-secondary ms-2" @onclick="() => CopyToClipboard(baseUrl)">
                                <i class="oi oi-clipboard"></i> Copy
                            </button>
                        </dd>

                        <dt class="col-sm-3">SCIM Version:</dt>
                        <dd class="col-sm-9"><span class="badge bg-primary">SCIM 2.0</span></dd>

                        <dt class="col-sm-3">Authentication:</dt>
                        <dd class="col-sm-9">Bearer Token (JWT)</dd>

                        <dt class="col-sm-3">Content-Type:</dt>
                        <dd class="col-sm-9"><code>application/scim+json</code></dd>
                    </dl>
                </div>
            </div>

            <!-- SCIM Endpoints -->
            <div class="card mb-4">
                <div class="card-header">
                    <h3 class="mb-0"><i class="oi oi-list"></i> SCIM Endpoints</h3>
                </div>
                <div class="card-body">
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>Resource</th>
                                <th>Endpoint</th>
                                <th>Operations</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td><strong>Users</strong></td>
                                <td><code>/scim/v2/Users</code></td>
                                <td>
                                    <span class="badge bg-success">GET</span>
                                    <span class="badge bg-primary">POST</span>
                                    <span class="badge bg-warning">PUT</span>
                                    <span class="badge bg-info">PATCH</span>
                                    <span class="badge bg-danger">DELETE</span>
                                </td>
                            </tr>
                            <tr>
                                <td><strong>Groups</strong></td>
                                <td><code>/scim/v2/Groups</code></td>
                                <td>
                                    <span class="badge bg-success">GET</span>
                                    <span class="badge bg-primary">POST</span>
                                    <span class="badge bg-warning">PUT</span>
                                    <span class="badge bg-info">PATCH</span>
                                    <span class="badge bg-danger">DELETE</span>
                                </td>
                            </tr>
                            <tr>
                                <td><strong>Schemas</strong></td>
                                <td><code>/scim/v2/Schemas</code></td>
                                <td><span class="badge bg-success">GET</span></td>
                            </tr>
                            <tr>
                                <td><strong>Resource Types</strong></td>
                                <td><code>/scim/v2/ResourceTypes</code></td>
                                <td><span class="badge bg-success">GET</span></td>
                            </tr>
                            <tr>
                                <td><strong>Service Provider Config</strong></td>
                                <td><code>/scim/v2/ServiceProviderConfig</code></td>
                                <td><span class="badge bg-success">GET</span></td>
                            </tr>
                            <tr>
                                <td><strong>Bulk Operations</strong></td>
                                <td><code>/scim/v2/Bulk</code></td>
                                <td><span class="badge bg-primary">POST</span></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Authentication -->
            <div class="card mb-4">
                <div class="card-header">
                    <h3 class="mb-0"><i class="oi oi-key"></i> Authentication</h3>
                </div>
                <div class="card-body">
                    <p>All SCIM requests must include an Authorization header with a valid Bearer token:</p>
                    <pre class="bg-light p-3"><code>Authorization: Bearer &lt;your-api-token&gt;</code></pre>
                    
                    <div class="alert alert-info">
                        <i class="oi oi-info"></i> <strong>Get an API Token:</strong> 
                        Go to <a href="/tokens" class="alert-link">API Tokens</a> to create a new token for authentication.
                    </div>
                </div>
            </div>

            <!-- Example Requests -->
            <div class="card mb-4">
                <div class="card-header">
                    <h3 class="mb-0"><i class="oi oi-code"></i> Example Requests</h3>
                </div>
                <div class="card-body">
                    <div class="drawer-tabs" style="margin: 0; border-bottom: 1px solid var(--line);">
                        <button class="@(exampleTab == "curl" ? "cur" : "")" @onclick='() => exampleTab = "curl"'>cURL</button>
                        <button class="@(exampleTab == "postman" ? "cur" : "")" @onclick='() => exampleTab = "postman"'>Postman</button>
                        <button class="@(exampleTab == "powershell" ? "cur" : "")" @onclick='() => exampleTab = "powershell"'>PowerShell</button>
                    </div>
                    <div class="mt-3">
                        <div style="display: @(exampleTab == "curl" ? "block" : "none");">
                            <h5>Get All Users</h5>
                            <pre class="bg-light p-3"><code>curl -X GET "@baseUrl/scim/v2/Users" \
  -H "Authorization: Bearer YOUR_TOKEN" \
  -H "Accept: application/scim+json"</code></pre>

                            <h5>Create User</h5>
                            <pre class="bg-light p-3"><code>curl -X POST "@baseUrl/scim/v2/Users" \
  -H "Authorization: Bearer YOUR_TOKEN" \
  -H "Content-Type: application/scim+json" \
  -d '{
    "schemas": ["urn:ietf:params:scim:schemas:core:2.0:User"],
    "userName": "john.doe@example.com",
    "name": {
      "givenName": "John",
      "familyName": "Doe"
    },
    "emails": [{
      "value": "john.doe@example.com",
      "type": "work",
      "primary": true
    }],
    "active": true
  }'</code></pre>

                            <h5>Search Users with Filter</h5>
                            <pre class="bg-light p-3"><code>curl -X GET "@baseUrl/scim/v2/Users?filter=userName%20eq%20%22john.doe@example.com%22" \
  -H "Authorization: Bearer YOUR_TOKEN" \
  -H "Accept: application/scim+json"</code></pre>
                        </div>
                        
                        <div style="display: @(exampleTab == "postman" ? "block" : "none");">
                            <h5>Postman Configuration</h5>
                            <ol>
                                <li>Create a new request in Postman</li>
                                <li>Set the request type (GET, POST, etc.)</li>
                                <li>Enter the URL: <code>@baseUrl/scim/v2/Users</code></li>
                                <li>Go to the <strong>Authorization</strong> tab</li>
                                <li>Select <strong>Bearer Token</strong> as the type</li>
                                <li>Enter your API token</li>
                                <li>Go to the <strong>Headers</strong> tab</li>
                                <li>Add header: <code>Accept: application/scim+json</code></li>
                                <li>For POST/PUT/PATCH, add: <code>Content-Type: application/scim+json</code></li>
                            </ol>
                        </div>
                        
                        <div style="display: @(exampleTab == "powershell" ? "block" : "none");">
                            <h5>Get All Users</h5>
                            <pre class="bg-light p-3"><code>$headers = @@{
    "Authorization" = "Bearer YOUR_TOKEN"
    "Accept" = "application/scim+json"
}
Invoke-RestMethod -Uri "@baseUrl/scim/v2/Users" -Headers $headers -Method Get</code></pre>

                            <h5>Create User</h5>
                            <pre class="bg-light p-3"><code>$headers = @@{
    "Authorization" = "Bearer YOUR_TOKEN"
    "Content-Type" = "application/scim+json"
}
$body = @@{
    schemas = @@("urn:ietf:params:scim:schemas:core:2.0:User")
    userName = "john.doe@example.com"
    name = @@{
        givenName = "John"
        familyName = "Doe"
    }
    emails = @@(
        @@{
            value = "john.doe@example.com"
            type = "work"
            primary = $true
        }
    )
    active = $true
} | ConvertTo-Json -Depth 10

Invoke-RestMethod -Uri "@baseUrl/scim/v2/Users" -Headers $headers -Method Post -Body $body</code></pre>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Test Connection -->
            <div class="card mb-4">
                <div class="card-header">
                    <h3 class="mb-0"><i class="oi oi-pulse"></i> Test Connection</h3>
                </div>
                <div class="card-body">
                    <p>Test your SCIM connection by checking the Service Provider Configuration:</p>
                    
                    <div class="input-group mb-3">
                        <input type="text" class="form-control" @bind="testToken" placeholder="Enter your API token" />
                        <button class="btn btn-primary" @onclick="TestConnection" disabled="@testing">
                            @if (testing)
                            {
                                <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                            }
                            Test Connection
                        </button>
                    </div>

                    @if (!string.IsNullOrEmpty(testResult))
                    {
                        @if (testSuccess)
                        {
                            <div class="alert alert-success mt-3">
                                <h6 class="alert-heading">✓ Connection Successful!</h6>
                                <p>Your API token is valid and the SCIM server is responding correctly.</p>
                                <hr>
                                <details>
                                    <summary class="cursor-pointer">View Service Provider Configuration</summary>
                                    <pre class="mt-2 mb-0 bg-light p-2 rounded"><code>@testResult</code></pre>
                                </details>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-danger mt-3">
                                <h6 class="alert-heading">✗ Connection Failed</h6>
                                <pre class="mb-0">@testResult</pre>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>

        <!-- Right Sidebar -->
        <div class="col-lg-4">
            <!-- Quick Links -->
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0">Quick Links</h5>
                </div>
                <div class="card-body">
                    <div class="d-grid gap-2">
                        <a href="/tokens" class="btn btn-outline-primary">
                            <i class="oi oi-key"></i> Manage API Tokens
                        </a>
                        <a href="/api-explorer" class="btn btn-outline-primary">
                            <i class="oi oi-code"></i> API Explorer
                        </a>
                        <a href="/users" class="btn btn-outline-primary">
                            <i class="oi oi-people"></i> View Users
                        </a>
                        <a href="/groups" class="btn btn-outline-primary">
                            <i class="oi oi-layers"></i> View Groups
                        </a>
                    </div>
                </div>
            </div>

            <!-- SCIM Resources -->
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0">SCIM Resources</h5>
                </div>
                <div class="card-body">
                    <ul class="list-unstyled">
                        <li class="mb-2">
                            <a href="https://datatracker.ietf.org/doc/html/rfc7644" target="_blank" rel="noopener">
                                <i class="oi oi-external-link"></i> SCIM 2.0 Protocol (RFC 7644)
                            </a>
                        </li>
                        <li class="mb-2">
                            <a href="https://datatracker.ietf.org/doc/html/rfc7643" target="_blank" rel="noopener">
                                <i class="oi oi-external-link"></i> SCIM 2.0 Core Schema (RFC 7643)
                            </a>
                        </li>
                        <li class="mb-2">
                            <a href="https://tools.ietf.org/html/rfc7642" target="_blank" rel="noopener">
                                <i class="oi oi-external-link"></i> SCIM 2.0 Definitions (RFC 7642)
                            </a>
                        </li>
                    </ul>
                </div>
            </div>

            <!-- Common Filters -->
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Common SCIM Filters</h5>
                </div>
                <div class="card-body">
                    <p class="small text-muted">Examples of SCIM filter syntax:</p>
                    <ul class="list-unstyled small">
                        <li class="mb-2"><code>userName eq "john"</code></li>
                        <li class="mb-2"><code>name.familyName co "smith"</code></li>
                        <li class="mb-2"><code>emails[type eq "work"].value sw "john"</code></li>
                        <li class="mb-2"><code>active eq true</code></li>
                        <li class="mb-2"><code>meta.created gt "2024-01-01"</code></li>
                        <li class="mb-2"><code>userName pr and active eq true</code></li>
                    </ul>
                    <p class="small text-muted mb-0">
                        <strong>Operators:</strong> eq (equals), ne (not equals), co (contains), 
                        sw (starts with), ew (ends with), gt (greater than), 
                        lt (less than), ge (&gt;=), le (&lt;=), pr (present)
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .cursor-pointer {
        cursor: pointer;
        user-select: none;
    }
    
    .cursor-pointer:hover {
        color: var(--bs-primary);
    }
    
    details summary::-webkit-details-marker {
        color: var(--bs-primary);
    }
</style>

@code {
    private string baseUrl = "";
    private string testToken = "";
    private bool testing = false;
    private string testResult = "";
    private bool testSuccess = false;
    // Active example-requests tab. Bootstrap's data-bs-toggle tabs need
    // bootstrap.bundle.js which we don't load — driving them with Blazor state
    // instead matches the rest of the app (drawer, modal, etc).
    private string exampleTab = "curl";

    protected override void OnInitialized()
    {
        // Get the base URL
        var uri = new Uri(Navigation.Uri);
        baseUrl = $"{uri.Scheme}://{uri.Authority}";
    }

    private async Task TestConnection()
    {
        if (string.IsNullOrWhiteSpace(testToken))
        {
            testResult = "Please enter an API token";
            testSuccess = false;
            return;
        }

        testing = true;
        testResult = "";
        StateHasChanged();

        try
        {
            using var client = new HttpClient();
            client.BaseAddress = new Uri(baseUrl);
            client.DefaultRequestHeaders.Authorization = 
                new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", testToken);
            client.DefaultRequestHeaders.Accept.Add(
                new System.Net.Http.Headers.MediaTypeWithQualityHeaderValue("application/scim+json"));

            var response = await client.GetAsync("/scim/v2/ServiceProviderConfig");
            
            if (response.IsSuccessStatusCode)
            {
                var content = await response.Content.ReadAsStringAsync();
                
                // Parse and format JSON response
                try
                {
                    var json = System.Text.Json.JsonDocument.Parse(content);
                    var formatted = System.Text.Json.JsonSerializer.Serialize(json, new System.Text.Json.JsonSerializerOptions
                    {
                        WriteIndented = true
                    });
                    testResult = formatted;
                }
                catch
                {
                    testResult = content;
                }
                
                testSuccess = true;
            }
            else
            {
                testResult = $"✗ Connection failed!\n\nStatus: {response.StatusCode}\nReason: {response.ReasonPhrase}";
                testSuccess = false;
            }
        }
        catch (Exception ex)
        {
            testResult = $"✗ Connection error!\n\n{ex.Message}";
            testSuccess = false;
        }
        finally
        {
            testing = false;
        }
    }

    private async Task CopyToClipboard(string text)
    {
        await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", text);
    }

    [Inject]
    private IJSRuntime JSRuntime { get; set; } = default!;
}