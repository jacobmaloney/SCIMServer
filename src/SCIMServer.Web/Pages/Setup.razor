@page "/setup"
@using SCIMServer.Web.Services
@using System.Security.Cryptography
@inject SetupService SetupService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@inject IConfiguration Configuration
@layout SetupLayout

<div class="wizard-shell">
    <aside class="wizard-aside">
        <div class="wizard-brand">
            <i class="oi oi-cloud" style="color: var(--accent); font-size: 1.25rem;"></i>
            <span><b>SCIM</b><span class="brand-suffix">Server</span></span>
        </div>
        <div class="wizard-steps">
            @foreach (var (label, num) in StepList())
            {
                var state = num == currentStep ? "cur" : (num < currentStep ? "done" : "");
                <div class="wizard-step @state">
                    <span class="wizard-step-num">
                        @if (num < currentStep)
                        {
                            <i class="oi oi-check" style="font-size: 9px;"></i>
                        }
                        else
                        {
                            @num
                        }
                    </span>
                    <span>@label</span>
                </div>
            }
        </div>
        <div class="wizard-aside-foot">
            <div class="wizard-aside-foot-label">Need help?</div>
            <a href="https://datatracker.ietf.org/doc/html/rfc7644" target="_blank" style="color: var(--accent); font-weight: 500; text-decoration: none;">SCIM 2.0 spec →</a>
        </div>
    </aside>

    <main class="wizard-main">
        <div class="wizard-pane">
            @if (isProcessing)
            {
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Setting up...</span>
                    </div>
                    <p class="mt-3 text-muted">Setting up SCIM Server, please wait...</p>
                </div>
            }
            else if (setupComplete)
            {
                <div class="wizard-eyebrow">All set</div>
                <h1 class="wizard-h1">Setup <span class="hl">complete</span>.</h1>
                <p class="wizard-lede">SCIM Server has been successfully configured. Redirecting to the login page…</p>
            }
            else
            {
                <div class="wizard-eyebrow">First-run setup · @StepList()[currentStep - 1].label</div>
                <h1 class="wizard-h1">@WizardHeading()</h1>
                <p class="wizard-lede">@WizardLede()</p>

                <EditForm Model="@config" OnValidSubmit="@HandleValidSubmit">
                    <DataAnnotationsValidator />

                            @if (currentStep == 1)
                            {
                                <!-- Step 1: Database Configuration -->
                                <h4>Database Configuration</h4>
                                <p class="text-muted">Configure the database connection for SCIM Server.</p>

                                <div class="mb-3">
                                    <label class="form-label">Database Type</label>
                                    <select class="form-select" @bind="databaseType">
                                        <option value="localdb">SQL Server LocalDB (Development)</option>
                                        <option value="sqlexpress">SQL Server Express</option>
                                        <option value="sqlserver">SQL Server</option>
                                        <option value="custom">Custom Connection String</option>
                                    </select>
                                </div>

                                @if (databaseType == "localdb")
                                {
                                    <div class="mb-3">
                                        <label class="form-label">Database Name</label>
                                        <input type="text" class="form-control" @bind="databaseName" placeholder="SCIMServer" />
                                        <small class="form-text text-muted">
                                            Defaults to <code>SCIMServer</code>. Use suffixes like <code>SCIMServerUSA1</code> to run multiple instances side-by-side.
                                        </small>
                                    </div>
                                }

                                @if (databaseType == "sqlexpress" || databaseType == "sqlserver")
                                {
                                    <div class="mb-3">
                                        <label class="form-label">Server Name</label>
                                        <input type="text" class="form-control" @bind="serverName"
                                               placeholder="@(databaseType == "sqlexpress" ? ".\\SQLEXPRESS" : "localhost")" />
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label">Database Name</label>
                                        <input type="text" class="form-control" @bind="databaseName" placeholder="SCIMServer" />
                                        <small class="form-text text-muted">
                                            Defaults to <code>SCIMServer</code>. Use suffixes like <code>SCIMServerUSA1</code>, <code>SCIMServerUSA2</code> to run multiple instances side-by-side on one server.
                                        </small>
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label">Authentication</label>
                                        <select class="form-select" @bind="authType">
                                            <option value="windows">Windows Authentication</option>
                                            <option value="sql">SQL Server Authentication</option>
                                        </select>
                                    </div>

                                    @if (authType == "sql")
                                    {
                                        <div class="mb-3">
                                            <label class="form-label">Username</label>
                                            <input type="text" class="form-control" @bind="dbUsername" />
                                        </div>

                                        <div class="mb-3">
                                            <label class="form-label">Password</label>
                                            <input type="password" class="form-control" @bind="dbPassword" />
                                        </div>
                                    }

                                    <div class="form-check mb-2">
                                        <input type="checkbox" class="form-check-input" id="trustServerCertificate" @bind="trustServerCertificate" />
                                        <label class="form-check-label" for="trustServerCertificate">
                                            Trust server certificate (use for self-signed SSL certificates)
                                        </label>
                                        <small class="form-text text-muted d-block">
                                            Enable this if you're getting SSL certificate trust errors. Not recommended for production.
                                        </small>
                                    </div>

                                    <div class="form-check mb-3">
                                        <input type="checkbox" class="form-check-input" id="encryptConnection" @bind="encryptConnection" />
                                        <label class="form-check-label" for="encryptConnection">
                                            Encrypt connection
                                        </label>
                                        <small class="form-text text-muted d-block">
                                            Uncheck this to disable encryption. May help with SSPI context errors.
                                        </small>
                                    </div>
                                }
                                else if (databaseType == "custom")
                                {
                                    <div class="mb-3">
                                        <label class="form-label">Connection String</label>
                                        <textarea class="form-control" rows="3" @bind="config.ConnectionString"
                                                  placeholder="Server=localhost;Database=SCIMServer;..."></textarea>
                                    </div>
                                }

                                <div class="mb-3">
                                    <button type="button" class="btn btn-sm btn-secondary" @onclick="TestConnection" disabled="@testingConnection">
                                        @if (testingConnection)
                                        {
                                            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                        }
                                        Test Connection
                                    </button>
                                    @if (connectionTest != null)
                                    {
                                        var alertClass = GetTestAlertClass();
                                        <div class="mt-2 alert @alertClass py-2">
                                            @GetTestMessage()
                                            @if (!connectionTest.ServerReachable && !string.IsNullOrEmpty(connectionTest.ErrorMessage) &&
                                                 (connectionTest.ErrorMessage.Contains("SSPI") || connectionTest.ErrorMessage.Contains("principal name")))
                                            {
                                                <hr class="my-2" />
                                                <small>
                                                    <strong>SSPI Error Help:</strong>
                                                    <ul class="mb-0 ps-3">
                                                        <li>Try switching to SQL Server Authentication instead of Windows Authentication</li>
                                                        <li>Uncheck "Encrypt connection" above</li>
                                                        <li>Verify the server name is correct (use computer name instead of IP)</li>
                                                        <li>Check if SQL Server Browser service is running</li>
                                                    </ul>
                                                </small>
                                            }
                                            @if (connectionTest.ServerReachable && !connectionTest.DatabaseExists && !string.IsNullOrWhiteSpace(connectionTest.DatabaseName))
                                            {
                                                <hr class="my-2" />
                                                <div class="d-flex align-items-center gap-2 flex-wrap">
                                                    <button type="button" class="btn btn-sm btn-warning" @onclick="CreateDatabaseNow" disabled="@creatingDatabase">
                                                        @if (creatingDatabase)
                                                        {
                                                            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                                        }
                                                        Create Database Now
                                                    </button>
                                                    <div class="form-check ms-2 mb-0">
                                                        <input type="checkbox" class="form-check-input" id="autoCreateDb" @bind="autoCreateDatabase" />
                                                        <label class="form-check-label" for="autoCreateDb">
                                                            Create on setup completion
                                                        </label>
                                                    </div>
                                                </div>
                                                @if (!string.IsNullOrEmpty(createDatabaseMessage))
                                                {
                                                    <div class="small mt-2 @(createDatabaseSuccess ? "text-success" : "text-danger")">
                                                        @createDatabaseMessage
                                                    </div>
                                                }
                                            }
                                        </div>
                                    }
                                </div>
                            }
                            else if (currentStep == 2)
                            {
                                <!-- Step 2: Admin User -->
                                <h4>Administrator Account</h4>
                                <p class="text-muted">Create the administrator account for SCIM Server.</p>

                                <div class="mb-3">
                                    <label class="form-label">Admin Username</label>
                                    <InputText class="form-control" @bind-Value="config.AdminUsername" />
                                    <ValidationMessage For="@(() => config.AdminUsername)" />
                                </div>

                                <div class="mb-3">
                                    <label class="form-label">Admin Password</label>
                                    <InputText type="password" class="form-control" @bind-Value="config.AdminPassword" />
                                    <ValidationMessage For="@(() => config.AdminPassword)" />
                                    <small class="form-text text-muted">Minimum 8 characters</small>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label">Confirm Password</label>
                                    <input type="password" class="form-control" @bind="confirmPassword" />
                                    @if (!string.IsNullOrEmpty(confirmPassword) && confirmPassword != config.AdminPassword)
                                    {
                                        <div class="text-danger small mt-1">Passwords do not match</div>
                                    }
                                </div>
                            }
                            else if (currentStep == 3)
                            {
                                <!-- Step 3: Security Settings -->
                                <h4>Security Configuration</h4>
                                <p class="text-muted">Configure security settings for SCIM Server.</p>

                                <div class="mb-3">
                                    <label class="form-label">JWT Secret Key</label>
                                    <div class="input-group">
                                        <input type="text" class="form-control" @bind="config.JwtSecretKey" readonly />
                                        <button type="button" class="btn btn-outline-secondary" @onclick="GenerateSecretKey">
                                            Generate New
                                        </button>
                                    </div>
                                    <small class="form-text text-muted">This key is used to sign JWT tokens. Keep it secure!</small>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label">Server Port</label>
                                    <InputNumber class="form-control" @bind-Value="config.ServerPort" />
                                </div>

                                <div class="form-check mb-3">
                                    <InputCheckbox class="form-check-input" @bind-Value="config.UseHttps" />
                                    <label class="form-check-label">
                                        Enable HTTPS (recommended for production)
                                    </label>
                                </div>
                            }
                            else if (currentStep == 4)
                            {
                                <!-- Step 4: Review -->
                                <h4>Review Configuration</h4>
                                <p class="text-muted">Please review your settings before completing setup.</p>

                                <dl class="row">
                                    <dt class="col-sm-4">Server</dt>
                                    <dd class="col-sm-8">
                                        @if (databaseType == "localdb")
                                        {
                                            <text>SQL Server LocalDB</text>
                                        }
                                        else if (databaseType == "custom")
                                        {
                                            <text>Custom</text>
                                        }
                                        else
                                        {
                                            <text>@serverName</text>
                                        }
                                    </dd>

                                    @if (databaseType != "custom")
                                    {
                                        <dt class="col-sm-4">Database Name</dt>
                                        <dd class="col-sm-8">@(string.IsNullOrWhiteSpace(databaseName) ? "SCIMServer" : databaseName)</dd>
                                    }

                                    <dt class="col-sm-4">Admin Username</dt>
                                    <dd class="col-sm-8">@config.AdminUsername</dd>

                                    <dt class="col-sm-4">Server URL</dt>
                                    <dd class="col-sm-8">@(config.UseHttps ? "https" : "http")://localhost:@config.ServerPort</dd>

                                    <dt class="col-sm-4">JWT Security</dt>
                                    <dd class="col-sm-8">✓ Configured</dd>
                                </dl>

                                @if (errors.Any())
                                {
                                    <div class="alert alert-danger">
                                        <h6>Please fix the following errors:</h6>
                                        <ul class="mb-0">
                                            @foreach (var error in errors)
                                            {
                                                <li>@error</li>
                                            }
                                        </ul>
                                    </div>
                                }
                            }

                    <div class="wizard-foot">
                        <button type="button" class="btn btn-outline-secondary" @onclick="PreviousStep"
                                disabled="@(currentStep == 1)">
                            ← Previous
                        </button>

                        @if (currentStep < 4)
                        {
                            <button type="button" class="btn btn-primary" @onclick="NextStep">
                                Next →
                            </button>
                        }
                        else
                        {
                            <button type="submit" class="btn btn-primary" disabled="@isProcessing">
                                Complete Setup
                            </button>
                        }
                    </div>
                </EditForm>
            }
        </div>
    </main>
</div>

<style>
    .step-indicator {
        margin-bottom: 2rem;
    }

    .step {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background-color: #e9ecef;
        color: #6c757d;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        margin: 0 auto;
    }

    .step.active {
        background-color: #0d6efd;
        color: white;
    }
</style>

@code {
    private static readonly (string label, int num)[] _steps = new[]
    {
        ("Database", 1),
        ("Admin user", 2),
        ("Security", 3),
        ("Review", 4)
    };
    private static (string label, int num)[] StepList() => _steps;

    private string WizardHeading() => currentStep switch
    {
        1 => "Connect a database.",
        2 => "Create your admin.",
        3 => "Lock things down.",
        4 => "Review and go.",
        _ => "SCIM Server setup."
    };

    private string WizardLede() => currentStep switch
    {
        1 => "Where should SCIM Server store users, groups, tokens, and audit logs? Point it at a SQL Server you can reach; we'll create the database for you if it doesn't exist yet.",
        2 => "The first user to sign in to the portal. Pick something memorable — you can rotate the password later from the admin panel.",
        3 => "JWT signing key and the public port the SCIM API will bind to. Defaults are sensible; only change them if you have a reason.",
        4 => "Last look before we apply everything. Nothing has been written yet.",
        _ => ""
    };

    private SetupConfiguration config = new();
    private int currentStep = 1;
    private bool isProcessing = false;
    private bool setupComplete = false;
    private List<string> errors = new();

    // Database configuration
    private string databaseType = "sqlserver";
    private string serverName = "localhost";
    private string databaseName = "SCIMServer";
    private string authType = "sql";
    private string dbUsername = "sa";
    private string dbPassword = "";
    private bool trustServerCertificate = true;
    private bool encryptConnection = false;

    // Password confirmation
    private string confirmPassword = "";

    // Connection test
    private bool testingConnection = false;
    private ConnectionTestResult? connectionTest;
    private bool autoCreateDatabase = true;
    private bool creatingDatabase = false;
    private string createDatabaseMessage = "";
    private bool createDatabaseSuccess = false;

    protected override async Task OnInitializedAsync()
    {
        // Check if setup is required
        var setupRequired = await SetupService.IsSetupRequiredAsync();
        if (!setupRequired)
        {
            Navigation.NavigateTo("/");
        }

        // Generate initial secret key
        GenerateSecretKey();
    }

    private void NextStep()
    {
        errors.Clear();

        // Validate current step
        if (currentStep == 1)
        {
            UpdateConnectionString();
            if (string.IsNullOrWhiteSpace(config.ConnectionString))
            {
                errors.Add("Please configure the database connection");
                return;
            }
            if (connectionTest == null)
            {
                errors.Add("Please test the connection before continuing.");
                return;
            }
            if (!connectionTest.ServerReachable)
            {
                errors.Add("Database server is not reachable. Fix the connection and re-test.");
                return;
            }
            if (!connectionTest.DatabaseExists && !autoCreateDatabase)
            {
                errors.Add($"Database '{connectionTest.DatabaseName}' does not exist. Either create it now, or check 'Create on setup completion'.");
                return;
            }
            config.AutoCreateDatabase = autoCreateDatabase;
        }
        else if (currentStep == 2)
        {
            if (string.IsNullOrWhiteSpace(config.AdminUsername))
            {
                errors.Add("Admin username is required");
                return;
            }
            if (string.IsNullOrWhiteSpace(config.AdminPassword) || config.AdminPassword.Length < 8)
            {
                errors.Add("Admin password must be at least 8 characters");
                return;
            }
            if (config.AdminPassword != confirmPassword)
            {
                errors.Add("Passwords do not match");
                return;
            }
        }

        if (currentStep < 4)
        {
            currentStep++;
        }
    }

    private void PreviousStep()
    {
        if (currentStep > 1)
        {
            currentStep--;
        }
    }

    private void UpdateConnectionString()
    {
        var db = string.IsNullOrWhiteSpace(databaseName) ? "SCIMServer" : databaseName.Trim();

        if (databaseType == "localdb")
        {
            config.ConnectionString = $"Server=(localdb)\\mssqllocaldb;Database={db};Trusted_Connection=True;";
        }
        else if (databaseType == "sqlexpress" || databaseType == "sqlserver")
        {
            var server = string.IsNullOrWhiteSpace(serverName)
                ? (databaseType == "sqlexpress" ? ".\\SQLEXPRESS" : "localhost")
                : serverName;

            if (authType == "windows")
            {
                config.ConnectionString = $"Server={server};Database={db};Trusted_Connection=True;";
            }
            else
            {
                config.ConnectionString = $"Server={server};Database={db};User Id={dbUsername};Password={dbPassword};";
            }

            // Add encryption settings
            if (!encryptConnection)
            {
                config.ConnectionString += "Encrypt=False;";
            }

            // Add TrustServerCertificate if enabled
            if (trustServerCertificate)
            {
                config.ConnectionString += "TrustServerCertificate=True;";
            }
        }
    }

    private async Task TestConnection()
    {
        testingConnection = true;
        createDatabaseMessage = "";
        UpdateConnectionString();

        try
        {
            connectionTest = await SetupService.TestConnectionAsync(config.ConnectionString);
        }
        finally
        {
            testingConnection = false;
        }
    }

    private async Task CreateDatabaseNow()
    {
        if (connectionTest == null) return;
        creatingDatabase = true;
        createDatabaseMessage = "";
        try
        {
            var (success, message) = await SetupService.CreateDatabaseAsync(config.ConnectionString);
            createDatabaseSuccess = success;
            createDatabaseMessage = message;
            if (success)
            {
                connectionTest = await SetupService.TestConnectionAsync(config.ConnectionString);
            }
        }
        finally
        {
            creatingDatabase = false;
        }
    }

    private string GetTestAlertClass()
    {
        if (connectionTest == null) return "alert-secondary";
        if (!connectionTest.ServerReachable) return "alert-danger";
        if (!connectionTest.DatabaseExists) return "alert-warning";
        return "alert-success";
    }

    private string GetTestMessage()
    {
        if (connectionTest == null) return "";
        if (!connectionTest.ServerReachable)
        {
            return $"Connection failed: {connectionTest.ErrorMessage}";
        }
        if (!connectionTest.DatabaseExists)
        {
            return $"Connected to server, but database '{connectionTest.DatabaseName}' does not exist.";
        }
        if (!connectionTest.SchemaExists)
        {
            return $"Connected. Database '{connectionTest.DatabaseName}' exists but is empty — schema will be created on setup completion.";
        }
        return $"Connection successful. Database '{connectionTest.DatabaseName}' is ready (existing schema detected).";
    }

    private void GenerateSecretKey()
    {
        using var rng = RandomNumberGenerator.Create();
        var bytes = new byte[64];
        rng.GetBytes(bytes);
        config.JwtSecretKey = Convert.ToBase64String(bytes);
    }

    private async Task HandleValidSubmit()
    {
        isProcessing = true;
        errors.Clear();

        // Final validation
        var validationResult = SetupService.ValidateSetup(config);
        if (!validationResult.IsValid)
        {
            foreach (var errorList in validationResult.Errors.Values)
            {
                errors.AddRange(errorList);
            }
            isProcessing = false;
            return;
        }

        // Apply setup
        var success = await SetupService.ApplySetupAsync(config);
        if (success)
        {
            setupComplete = true;
            await Task.Delay(2000);
            // Force a hard reload to ensure the application restarts and picks up the new configuration
            await JSRuntime.InvokeVoidAsync("eval", "window.location.href = '/';");
        }
        else
        {
            errors.Add("Setup failed. Please check the logs for more information.");
            isProcessing = false;
        }
    }
}