@page "/connected-systems"
@attribute [Authorize]
@using SCIMServer.Core.Models
@using SCIMServer.DataAccess.Repositories
@using SCIMServer.Web.Services
@inject TenantRepository TenantRepo
@inject ApiTokenService Tokens
@inject DemoSeedService DemoSeed
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Connected Systems - SCIM Server</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1>Connected Systems</h1>
            <p class="text-muted">External identity targets this SCIM server connects to.</p>
        </div>
        <div>
            <button class="btn btn-outline-secondary me-2" @onclick="SeedDemo" disabled="@seeding">
                @if (seeding)
                {
                    <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                }
                <i class="oi oi-data-transfer-download"></i> Seed Demo Data
            </button>
            <button class="btn btn-primary" @onclick="ShowCreateModal">
                <i class="oi oi-plus"></i> + Connect a system
            </button>
        </div>
    </div>

    @if (lastSeedResult != null)
    {
        <div class="alert alert-success">
            <h5 class="alert-heading">Demo seed complete</h5>
            <p class="mb-1">
                Created: <strong>@lastSeedResult.ConnectedSystemsCreated</strong> connected systems,
                <strong>@lastSeedResult.UsersCreated</strong> users,
                <strong>@lastSeedResult.GroupsCreated</strong> groups,
                <strong>@lastSeedResult.MembershipsCreated</strong> memberships,
                <strong>@lastSeedResult.TokensCreated</strong> tokens.
            </p>
            @if (lastSeedResult.Notes.Any())
            {
                <details class="mt-2">
                    <summary>Details</summary>
                    <ul class="small mb-0">
                        @foreach (var n in lastSeedResult.Notes)
                        {
                            <li>@n</li>
                        }
                    </ul>
                </details>
            }
        </div>
    }

    @if (loading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (!stats.Any())
    {
        <div class="alert alert-info">
            <h4 class="alert-heading">No connected systems yet</h4>
            <p>Connect one to get started.</p>
            <button class="btn btn-primary btn-sm" @onclick="ShowCreateModal">
                <i class="oi oi-plus"></i> Connect a system
            </button>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var s in stats)
            {
                <div class="col-md-6 col-lg-4 mb-3">
                    <div class="card h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h5 class="card-title mb-0">@s.Name</h5>
                                @if (s.SystemType == "Real")
                                {
                                    <span class="badge bg-success">REAL</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">EMULATOR</span>
                                }
                            </div>
                            <p class="text-muted small mb-2">
                                <code>@s.Slug</code>
                                @if (!string.IsNullOrWhiteSpace(s.Domain))
                                {
                                    <span class="ms-2">@s.Domain</span>
                                }
                            </p>
                            @if (!s.IsActive)
                            {
                                <span class="badge bg-secondary mb-2">Inactive</span>
                            }
                            <div class="row text-center mt-3">
                                <div class="col">
                                    <div class="fw-bold">@s.UserCount</div>
                                    <small class="text-muted">Users</small>
                                </div>
                                <div class="col">
                                    <div class="fw-bold">@s.GroupCount</div>
                                    <small class="text-muted">Groups</small>
                                </div>
                                <div class="col">
                                    <div class="fw-bold">@s.TokenCount</div>
                                    <small class="text-muted">Tokens</small>
                                </div>
                            </div>
                        </div>
                        <div class="card-footer bg-transparent">
                            <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => ShowEndpoints(s)">
                                <i class="oi oi-link-intact"></i> Endpoints
                            </button>
                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => EditSystem(s.TenantId)">
                                <i class="oi oi-pencil"></i> Edit
                            </button>
                            @if (s.TenantId != TenantRepository.DefaultTenantId)
                            {
                                <button class="btn btn-sm btn-outline-danger float-end" @onclick="() => DeactivateSystem(s)">
                                    <i class="oi oi-ban"></i> Deactivate
                                </button>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<!-- Create / Edit modal -->
<div class="modal @(showModal ? "show d-block" : "")" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">@(editingId.HasValue ? "Edit Connected System" : "Connect a System")</h5>
                <button type="button" class="btn-close" @onclick="CloseModal"></button>
            </div>
            <div class="modal-body">
                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="alert alert-danger py-2">@errorMessage</div>
                }
                <div class="mb-3">
                    <label class="form-label">Name *</label>
                    <input class="form-control" @bind="form.Name" @bind:event="oninput" @bind:after="OnNameChanged" placeholder="e.g. Kodak — Entra ID Staging" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Slug *</label>
                    <input class="form-control" @bind="form.Slug" placeholder="kodak-entraid" />
                    <small class="form-text text-muted">URL-safe identifier. Auto-derived from the name; edit if needed. Unique across all systems.</small>
                </div>
                <div class="mb-3">
                    <label class="form-label">Domain</label>
                    <input class="form-control" @bind="form.Domain" placeholder="e.g. kodak.onmicrosoft.com (optional)" />
                </div>
                <div class="mb-3">
                    <label class="form-label">System Type *</label>
                    <select class="form-select" @bind="form.SystemType">
                        <option value="Emulator">Emulator (test/demo target)</option>
                        <option value="Real">Real (production target)</option>
                    </select>
                    <small class="form-text text-muted">Emulator systems show an amber badge. Real systems are green.</small>
                </div>
                <div class="mb-3">
                    <label class="form-label">Description</label>
                    <textarea class="form-control" rows="3" @bind="form.Description"></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="CloseModal">Cancel</button>
                <button class="btn btn-primary" @onclick="Save" disabled="@saving">
                    @if (saving)
                    {
                        <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                    }
                    @(editingId.HasValue ? "Save changes" : "Connect")
                </button>
            </div>
        </div>
    </div>
</div>

@if (showModal)
{
    <div class="modal-backdrop fade show"></div>
}

<!-- Endpoints modal -->
@if (endpointsFor != null)
{
    <div class="modal show d-block" tabindex="-1">
        <div class="modal-dialog modal-xl modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        Endpoints — @endpointsFor.Name
                        @if (endpointsFor.SystemType == "Real")
                        {
                            <span class="badge bg-success ms-2">REAL</span>
                        }
                        else
                        {
                            <span class="badge bg-warning text-dark ms-2">EMULATOR</span>
                        }
                    </h5>
                    <button class="btn-close" @onclick="CloseEndpoints"></button>
                </div>
                <div class="modal-body">
                    <p class="text-muted">
                        POST here from your ARS PowerShell workflows or any external app. The bearer token decides
                        which Connected System the request lands in — every token below is scoped to
                        <code>@endpointsFor.Slug</code>.
                    </p>

                    <h6 class="mt-3">URLs</h6>
                    <div class="table-responsive">
                        <table class="table table-sm table-bordered align-middle">
                            <thead class="table-light">
                                <tr><th style="width: 24%">Surface</th><th>URL</th><th style="width: 14%">Method</th><th style="width: 18%">Required scope</th></tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td><strong>SCIM 2.0</strong><br /><small class="text-muted">Users</small></td>
                                    <td><code>@baseUrl/scim/v2/Users</code></td>
                                    <td>POST / GET / PATCH</td>
                                    <td><span class="badge bg-info text-dark">Tenant</span></td>
                                </tr>
                                <tr>
                                    <td><strong>SCIM 2.0</strong><br /><small class="text-muted">Groups</small></td>
                                    <td><code>@baseUrl/scim/v2/Groups</code></td>
                                    <td>POST / GET / PATCH</td>
                                    <td><span class="badge bg-info text-dark">Tenant</span></td>
                                </tr>
                                <tr>
                                    <td><strong>Generic REST</strong><br /><small class="text-muted">Users</small></td>
                                    <td><code>@baseUrl/api/v1/users</code></td>
                                    <td>POST / GET / PATCH / DELETE</td>
                                    <td><span class="badge bg-info text-dark">Tenant</span></td>
                                </tr>
                                <tr>
                                    <td><strong>Generic REST</strong><br /><small class="text-muted">Groups</small></td>
                                    <td><code>@baseUrl/api/v1/groups</code></td>
                                    <td>POST / GET / DELETE</td>
                                    <td><span class="badge bg-info text-dark">Tenant</span></td>
                                </tr>
                                <tr>
                                    <td><strong>SQL emulator</strong><br /><small class="text-muted">Local SQL logins</small></td>
                                    <td><code>@baseUrl/sql/v1/accounts</code></td>
                                    <td>POST / GET / PATCH / DELETE</td>
                                    <td><span class="badge bg-info text-dark">Tenant</span></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <h6 class="mt-4">Tokens scoped to this Connected System</h6>
                    @if (endpointTokens.Count == 0)
                    {
                        <div class="alert alert-warning py-2">
                            No tokens are scoped to this system yet. Go to <a href="/tokens">API Tokens</a> to create one
                            (choose <strong>@endpointsFor.Name</strong> from the Connected System dropdown).
                        </div>
                    }
                    else
                    {
                        <table class="table table-sm table-bordered">
                            <thead class="table-light">
                                <tr><th>Name</th><th>Scope</th><th>Created</th><th>Bearer header</th></tr>
                            </thead>
                            <tbody>
                                @foreach (var t in endpointTokens)
                                {
                                    var demoRaw = LookupDemoToken(t.Name);
                                    <tr>
                                        <td>
                                            <strong>@t.Name</strong>
                                            @if (!string.IsNullOrEmpty(t.Description))
                                            {
                                                <br /><small class="text-muted">@t.Description</small>
                                            }
                                        </td>
                                        <td><span class="badge bg-info text-dark">@(string.IsNullOrEmpty(t.Scope) ? "Tenant" : t.Scope)</span></td>
                                        <td><small>@t.CreatedAt.ToString("yyyy-MM-dd")</small></td>
                                        <td>
                                            @if (demoRaw != null)
                                            {
                                                <code>Bearer scim_@demoRaw</code>
                                            }
                                            else
                                            {
                                                <span class="text-muted small">Raw token shown only at creation time — see <a href="/tokens">API Tokens</a> to mint a new one.</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }

                    <h6 class="mt-4">Example: create a user via SCIM</h6>
                    <pre class="bg-light p-3 mb-2 small" style="white-space: pre-wrap;"><code>@ScimCurlExample()</code></pre>

                    <h6 class="mt-4">Example: create a user via Generic REST</h6>
                    <pre class="bg-light p-3 mb-2 small" style="white-space: pre-wrap;"><code>@GenericCurlExample()</code></pre>

                    <h6 class="mt-4">Example: PowerShell <code>Invoke-RestMethod</code> from ARS workflow</h6>
                    <pre class="bg-light p-3 mb-0 small" style="white-space: pre-wrap;"><code>@PowershellExample()</code></pre>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseEndpoints">Close</button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

@code {
    private List<TenantStats> stats = new();
    private bool loading = true;
    private bool showModal;
    private bool saving;
    private bool seeding;
    private Guid? editingId;
    private Tenant form = new();
    private string errorMessage = "";
    private DemoSeedService.SeedResult? lastSeedResult;

    // Endpoints modal state
    private TenantStats? endpointsFor;
    private List<SCIMServer.Web.Services.ApiToken> endpointTokens = new();
    private string baseUrl = "";

    // Demo seed tokens (name → raw value) — only ones whose raw value is documented.
    // For any other token, raw value is unrecoverable from the hash by design.
    private static readonly Dictionary<string, string> KnownDemoTokens = new(StringComparer.OrdinalIgnoreCase)
    {
        { "kodak-entraid-token",  "demo-kodak-2024" },
        { "internal-app-token",   "demo-internal-2024" },
        { "admin-token",          "admin-scimserver-2024" },
        { "ars-proxy-token",      "ars-proxy-2024" }
    };

    private static string? LookupDemoToken(string name) =>
        KnownDemoTokens.TryGetValue(name, out var v) ? v : null;

    private async Task ShowEndpoints(TenantStats s)
    {
        endpointsFor = s;
        baseUrl = Navigation.BaseUri.TrimEnd('/');
        try
        {
            var all = await Tokens.GetAllTokensAsync();
            endpointTokens = all.Where(t => t.TenantId == s.TenantId).ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Failed to load tokens for endpoints view: {ex.Message}");
            endpointTokens = new();
        }
    }

    private void CloseEndpoints() => endpointsFor = null;

    private string DemoBearer() =>
        endpointTokens
            .Select(t => LookupDemoToken(t.Name))
            .FirstOrDefault(v => v != null) is { } raw
                ? $"scim_{raw}"
                : "scim_<your-token>";

    private string ExampleDomain()
    {
        var d = endpointsFor?.Domain;
        return string.IsNullOrWhiteSpace(d) ? "example.com" : d;
    }

    private string ScimCurlExample()
    {
        var bearer = DemoBearer();
        var domain = ExampleDomain();
        var url = baseUrl + "/scim/v2/Users";
        var sb = new System.Text.StringBuilder();
        sb.AppendLine("curl -X POST " + url + " \\");
        sb.AppendLine("  -H \"Authorization: Bearer " + bearer + "\" \\");
        sb.AppendLine("  -H \"Content-Type: application/scim+json\" \\");
        sb.AppendLine("  -d '{");
        sb.AppendLine("    \"schemas\": [\"urn:ietf:params:scim:schemas:core:2.0:User\"],");
        sb.AppendLine("    \"userName\": \"jsmith\",");
        sb.AppendLine("    \"name\": { \"givenName\": \"John\", \"familyName\": \"Smith\" },");
        sb.AppendLine("    \"emails\": [{ \"value\": \"jsmith@" + domain + "\", \"primary\": true }],");
        sb.AppendLine("    \"active\": true");
        sb.Append("  }'");
        return sb.ToString();
    }

    private string GenericCurlExample()
    {
        var bearer = DemoBearer();
        var domain = ExampleDomain();
        var url = baseUrl + "/api/v1/users";
        var sb = new System.Text.StringBuilder();
        sb.AppendLine("curl -X POST " + url + " \\");
        sb.AppendLine("  -H \"Authorization: Bearer " + bearer + "\" \\");
        sb.AppendLine("  -H \"Content-Type: application/json\" \\");
        sb.AppendLine("  -d '{");
        sb.AppendLine("    \"username\": \"jsmith\",");
        sb.AppendLine("    \"email\": \"jsmith@" + domain + "\",");
        sb.AppendLine("    \"firstName\": \"John\",");
        sb.AppendLine("    \"lastName\": \"Smith\",");
        sb.AppendLine("    \"active\": true");
        sb.Append("  }'");
        return sb.ToString();
    }

    private string PowershellExample()
    {
        var bearer = DemoBearer();
        var domain = ExampleDomain();
        var url = baseUrl + "/scim/v2/Users";
        var sb = new System.Text.StringBuilder();
        sb.AppendLine("$headers = @{");
        sb.AppendLine("    'Authorization' = 'Bearer " + bearer + "'");
        sb.AppendLine("    'Content-Type'  = 'application/scim+json'");
        sb.AppendLine("}");
        sb.AppendLine("$body = @{");
        sb.AppendLine("    schemas  = @('urn:ietf:params:scim:schemas:core:2.0:User')");
        sb.AppendLine("    userName = 'jsmith'");
        sb.AppendLine("    name     = @{ givenName = 'John'; familyName = 'Smith' }");
        sb.AppendLine("    emails   = @(@{ value = 'jsmith@" + domain + "'; primary = $true })");
        sb.AppendLine("    active   = $true");
        sb.AppendLine("} | ConvertTo-Json -Depth 5");
        sb.Append("Invoke-RestMethod -Method Post -Uri '" + url + "' -Headers $headers -Body $body");
        return sb.ToString();
    }

    private async Task SeedDemo()
    {
        var ok = await JS.InvokeAsync<bool>("confirm",
            "Seed demo data? This creates two Connected Systems (Kodak — Entra ID Staging, Internal App Demo), 25 users + 5 groups with the SOD trap pair, and four fixed-value API tokens. The operation is idempotent — re-running is safe.");
        if (!ok) return;
        seeding = true;
        lastSeedResult = null;
        try
        {
            lastSeedResult = await DemoSeed.SeedAsync();
            await Load();
        }
        catch (Exception ex)
        {
            errorMessage = $"Seed failed: {ex.Message}";
        }
        finally
        {
            seeding = false;
        }
    }

    protected override Task OnInitializedAsync() => Task.CompletedTask;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Load();
            StateHasChanged();
        }
    }

    private async Task Load()
    {
        loading = true;
        try { stats = await TenantRepo.GetStatsAsync(); }
        catch (Exception ex) { Console.WriteLine($"Failed to load connected systems: {ex.Message}"); }
        finally { loading = false; }
    }

    private void ShowCreateModal()
    {
        editingId = null;
        form = new Tenant { SystemType = "Emulator", IsActive = true };
        errorMessage = "";
        showModal = true;
    }

    private async Task EditSystem(Guid id)
    {
        var existing = await TenantRepo.GetByIdAsync(id);
        if (existing == null) return;
        editingId = id;
        form = existing;
        errorMessage = "";
        showModal = true;
    }

    private void CloseModal()
    {
        showModal = false;
        errorMessage = "";
    }

    private void OnNameChanged()
    {
        // Auto-derive slug when creating a new tenant and the slug field hasn't been hand-edited yet.
        if (editingId.HasValue) return;
        if (string.IsNullOrWhiteSpace(form.Name)) return;
        form.Slug = Slugify(form.Name);
    }

    private static string Slugify(string s)
    {
        var lower = s.ToLowerInvariant();
        var chars = lower.Select(c => char.IsLetterOrDigit(c) ? c : '-').ToArray();
        var collapsed = new string(chars);
        while (collapsed.Contains("--")) collapsed = collapsed.Replace("--", "-");
        return collapsed.Trim('-');
    }

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(form.Name) || string.IsNullOrWhiteSpace(form.Slug))
        {
            errorMessage = "Name and Slug are required.";
            return;
        }
        saving = true;
        errorMessage = "";
        try
        {
            if (editingId.HasValue)
            {
                form.Id = editingId.Value;
                await TenantRepo.UpdateAsync(form);
            }
            else
            {
                var clash = await TenantRepo.GetBySlugAsync(form.Slug);
                if (clash != null)
                {
                    errorMessage = $"A connected system with slug '{form.Slug}' already exists.";
                    return;
                }
                await TenantRepo.CreateAsync(form);
            }
            showModal = false;
            await Load();
        }
        catch (Exception ex)
        {
            errorMessage = $"Save failed: {ex.Message}";
        }
        finally
        {
            saving = false;
        }
    }

    private async Task DeactivateSystem(TenantStats s)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm",
            $"Deactivate '{s.Name}'? Users and groups in this system stay in the database but it will be hidden from active lists.");
        if (!confirmed) return;
        await TenantRepo.DeactivateAsync(s.TenantId);
        await Load();
    }
}
