@using SCIMServer.Web.Services
@inject GenerationService GenerationService
@implements IDisposable

@if (activeGenerations.Any())
{
    <div class="generation-status-container">
        @foreach (var generation in activeGenerations)
        {
            <div class="generation-status-item @(generation.Status == "Failed" ? "status-failed" : "")">
                <div class="status-header">
                    <span class="status-type">
                        <i class="oi @(generation.Type == "Users" ? "oi-people" : "oi-layers")"></i>
                        @generation.Type
                    </span>
                    <span class="status-time">@generation.GetElapsedTime()</span>
                </div>
                
                <div class="status-progress">
                    <div class="progress">
                        <div class="progress-bar @(generation.Status == "Failed" ? "bg-danger" : "progress-bar-striped progress-bar-animated")" 
                             role="progressbar" 
                             style="width: @generation.ProgressPercentage%"
                             aria-valuenow="@generation.ProgressPercentage" 
                             aria-valuemin="0" 
                             aria-valuemax="100">
                        </div>
                    </div>
                    <div class="progress-text">
                        @generation.CompletedItems / @generation.TotalItems
                        @if (generation.Status == "Completed")
                        {
                            <span class="text-success ms-2">✓ Complete</span>
                        }
                        else if (generation.Status == "Failed")
                        {
                            <span class="text-danger ms-2">✗ Failed</span>
                        }
                    </div>
                </div>
                
                @if (!string.IsNullOrEmpty(generation.Message))
                {
                    <div class="status-message">
                        <small>@generation.Message</small>
                    </div>
                }
            </div>
        }
    </div>
}

<style>
    .generation-status-container {
        position: fixed;
        bottom: 20px;
        right: 20px;
        z-index: 1050;
        max-width: 350px;
    }
    
    .generation-status-item {
        background: white;
        border: 1px solid #dee2e6;
        border-radius: 0.5rem;
        padding: 1rem;
        margin-bottom: 0.5rem;
        box-shadow: 0 0.25rem 0.75rem rgba(0, 0, 0, 0.1);
        animation: slideIn 0.3s ease-out;
    }
    
    .generation-status-item.status-failed {
        border-color: #dc3545;
    }
    
    .status-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 0.5rem;
        font-weight: 600;
    }
    
    .status-type i {
        margin-right: 0.25rem;
    }
    
    .status-time {
        font-size: 0.875rem;
        color: #6c757d;
    }
    
    .status-progress {
        margin-bottom: 0.25rem;
    }
    
    .progress {
        height: 8px;
        margin-bottom: 0.25rem;
    }
    
    .progress-text {
        font-size: 0.75rem;
        color: #6c757d;
        text-align: center;
    }
    
    .status-message {
        margin-top: 0.5rem;
        color: #6c757d;
    }
    
    @@keyframes slideIn {
        from {
            transform: translateX(100%);
            opacity: 0;
        }
        to {
            transform: translateX(0);
            opacity: 1;
        }
    }
</style>

@code {
    private List<SCIMServer.Web.Services.GenerationStatus> activeGenerations = new();
    private Timer? refreshTimer;
    
    protected override void OnInitialized()
    {
        // Refresh status every second
        refreshTimer = new Timer(RefreshStatus, null, TimeSpan.Zero, TimeSpan.FromSeconds(1));
    }
    
    private void RefreshStatus(object? state)
    {
        activeGenerations = GenerationService.GetActiveGenerations().ToList();
        
        // Also include recently completed generations for a few seconds
        var allGenerations = GenerationService.GetActiveGenerations()
            .Union(activeGenerations.Where(g => g.Status != "Running" && 
                   g.EndTime.HasValue && 
                   (DateTime.UtcNow - g.EndTime.Value).TotalSeconds < 5))
            .ToList();
            
        activeGenerations = allGenerations;
        
        // Clean up old generations
        GenerationService.ClearOldGenerations(30);
        
        InvokeAsync(StateHasChanged);
    }
    
    public void Dispose()
    {
        refreshTimer?.Dispose();
    }
}